# Copy this file to .env in the repository root.
# This file is for notebook and application secrets.

# OpenAI API key for notebooks that call OpenAI-compatible APIs. You can create a key at https://platform.openai.com/account/api-keys.
OPENAI_API_KEY=

# Email address used by edgartools when accessing SEC EDGAR. No registration is required, but a valid email address is required to access the SEC EDGAR system.
EDGAR_IDENTITY=

# Hugging Face token for models or datasets that require authentication to access. You can create a token at https://huggingface.co/settings/tokens.
HF_TOKEN=
