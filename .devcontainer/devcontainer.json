// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "DTCLLM-Intro-to-RAG",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/python:3-3.13-trixie",
	"features": {
		"ghcr.io/devcontainers-extra/features/uv:1": {}
	},

	"remoteUser": "vscode",

	// Mount caches from named Docker volumes
	"mounts": [
		"source=devcontainer-uv-cache,target=/home/vscode/.cache/uv,type=volume",
		"source=devcontainer-huggingface-cache,target=/home/vscode/.cache/huggingface,type=volume",
		"source=devcontainer-torch-cache,target=/home/vscode/.cache/torch,type=volume"
	],

	// Point tools to use mounted caches
	"remoteEnv": {
		"UV_CACHE_DIR": "/home/vscode/.cache/uv",
		"UV_LINK_MODE": "copy",
		"HF_HOME": "/home/vscode/.cache/huggingface",
		"TORCH_HOME": "/home/vscode/.cache/torch"
	},

	// VS Code customizations
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.debugpy",
				"ms-toolsai.jupyter",
				"ms-toolsai.jupyter-renderers"
			],
			"settings": {
				"python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
				"python.terminal.useEnvFile": true,
				"python.envFile": "${workspaceFolder}/.env",
				"jupyter.debugJustMyCode": false
			}
		}
	},

	"postCreateCommand": ".devcontainer/post-create.sh",
	"waitFor": "postCreateCommand"

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
