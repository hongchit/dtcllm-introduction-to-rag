// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "DTCLLM-Intro-to-RAG",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/python:3-3.14-trixie",
	"features": {
		"ghcr.io/devcontainers-extra/features/uv:1": {}
	},

	// Remove the default non-root user and replace with vscode
	"remoteUser": "vscode",
	"containerUser": "vscode",

	// Mount the UV cache from the named Docker volume
	"mounts": [
		"source=devcontainer-uv-cache,target=/home/vscode/.cache/uv,type=volume"
	],

	// Point uv to use the mounted cache
	"remoteEnv": {
		"UV_CACHE_DIR": "/home/vscode/.cache/uv",
		"UV_LINK_MODE": "copy"
	},

	// VS Code customizations
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.debugpy",
				"ms-toolsai.jupyter",
				"ms-toolsai.jupyter-renderers"
			],
			"settings": {
				"python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
				"debugpy.debugJustMyCode": false,
				"jupyter.debugJustMyCode": false,
				"launch": {
					"configurations": [
						{
							"name": "Python: Current File",
							"type": "debugpy",
							"request": "launch",
							"program": "${file}",
							"console": "integratedTerminal",
							"justMyCode": false
						},
						{
							"name": "Python: Module",
							"type": "debugpy",
							"request": "launch",
							"module": "${input:moduleName}",
							"console": "integratedTerminal",
							"justMyCode": false
						}
					],
					"inputs": [
						{
							"id": "moduleName",
							"type": "promptString",
							"description": "Python module to run"
						}
					]
				}
			}
		}
	},

	// Fix ownership of the UV cache volume (Docker creates it as root)
	"postCreateCommand": "sudo chown -R vscode:vscode /home/vscode/.cache/uv && uv sync --frozen && .venv/bin/python -m ipykernel install --user --name dtcllm-introduction-to-rag --display-name \"Python (.venv)\"",
	"waitFor": "postCreateCommand",

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	"forwardPorts": [
		8888
	],
	"portsAttributes": {
		"8888": {
			"label": "Jupyter",
			"onAutoForward": "notify"
		}
	},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
